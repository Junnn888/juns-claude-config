{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/block-git-commit.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/verify-on-stop.js\"",
            "timeout": 60000
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(git stash list *)",
      "Bash(git config --get *)",
      "Bash(git ls-files *)",
      "Bash(git shortlog *)",
      "Bash(git -C *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(echo *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(find *)",
      "Bash(jq *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(realpath *)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx tsc *)",
      "Bash(npx next *)",
      "Bash(npx vitest *)",
      "Bash(npx jest *)",
      "Bash(npx supabase *)",
      "Bash(bun *)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Agent",
      "Edit",
      "Write",
      "Skill",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop"
    ],
    "deny": [
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout . *)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  }
}
